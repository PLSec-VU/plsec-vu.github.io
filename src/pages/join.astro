---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Join | PLSec at VU Amsterdam">
  <PageHeader title="Join Us" intro="We welcome strong students and collaborators interested in programming languages, verification, and security." />
  <section class="section">
    <div class="container grid two">
      <article class="card">
        <h2>Students</h2>
        <p>Prospective MSc thesis students and research interns should include a short description of their interests, relevant coursework, and links to prior projects or writing.</p>
      </article>
      <article class="card">
        <h2>Collaborators</h2>
        <p>Researchers interested in joint work can reach out with a concise project idea, relevant background, and the kind of collaboration they have in mind.</p>
      </article>
    </div>
  </section>
</BaseLayout>
