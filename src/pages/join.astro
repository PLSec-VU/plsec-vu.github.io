---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Join | PLSec at VU Amsterdam">
  <PageHeader title="Join Us" intro="We welcome strong students interested in programming languages, verification, and security." />
  <section class="section">
    <div class="container grid two">
      <article class="card">
        <h2>BSc / MSc Students</h2>
        <p>Prospective thesis students should include a short description of their interests, relevant coursework, and links to prior projects or writing.</p>
      </article>
      <article class="card">
        <h2>PhD Students</h2>
        <p>Prospective PhD students should reach out with a CV, a short research idea, and a brief note explaining how their interests connect to the group.</p>
      </article>
    </div>
  </section>
</BaseLayout>
