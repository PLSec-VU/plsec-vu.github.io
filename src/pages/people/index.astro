---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const roleOrder = ['Faculty', 'Postdoc', 'PhD Student', 'Researcher', 'Collaborator', 'MSc Student', 'Alumni'];
const people = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const assetUrl = (path?: string) => path?.startsWith(base) ? path : path?.startsWith('/') ? withBase(path) : path;
const initials = (name: string) =>
  name
    .replace(/\([^)]*\)/g, '')
    .trim()
    .split(/\s+/)
    .map((part) => part[0])
    .join('')
    .slice(0, 2);
---

<BaseLayout title="People | PLSec at VU Amsterdam">
  <PageHeader title="People" intro="Researchers, students, collaborators, and alumni connected to the group." />
  <section class="section">
    <div class="container">
      {roleOrder.map((role) => {
        const group = people.filter((person) => person.data.role === role);
        return group.length > 0 && (
          <>
            <h2 class="role-heading">{role}</h2>
            <div class="grid">
              {group.map((person) => {
                const personHref = person.data.role === 'Alumni' ? person.data.website : withBase(`/people/${person.id}/`);
                const showPortrait = person.data.role !== 'Alumni';
                return (
                  <article class="card person">
                    {showPortrait && person.data.photo && personHref && (
                      <a href={personHref} aria-label={`View ${person.data.name}`}>
                        <img class="person-photo" src={assetUrl(person.data.photo)} alt="" />
                      </a>
                    )}
                    {showPortrait && person.data.photo && !personHref && <img class="person-photo" src={assetUrl(person.data.photo)} alt="" />}
                    {showPortrait && !person.data.photo && personHref && (
                      <a href={personHref} aria-label={`View ${person.data.name}`}>
                        <div class="person-photo person-initials" aria-hidden="true">
                          {initials(person.data.name)}
                        </div>
                      </a>
                    )}
                    {showPortrait && !person.data.photo && !personHref && (
                      <div class="person-photo person-initials" aria-hidden="true">
                        {initials(person.data.name)}
                      </div>
                    )}
                    <h3>{personHref ? <a href={personHref}>{person.data.name}</a> : person.data.name}</h3>
                    <p>{person.data.summary}</p>
                    {person.data.email && <a href={`mailto:${person.data.email}`}>Contact</a>}
                    {person.data.website && <a href={person.data.website}>Personal website</a>}
                    {person.data.interests.length > 0 && (
                      <div class="tags">
                        {person.data.interests.map((interest) => <span>{interest}</span>)}
                      </div>
                    )}
                  </article>
                );
              })}
            </div>
          </>
        );
      })}
    </div>
  </section>
</BaseLayout>
