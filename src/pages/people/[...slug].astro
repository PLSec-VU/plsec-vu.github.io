---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorList from '../../components/AuthorList.astro';

export async function getStaticPaths() {
  const people = (await getCollection('people')).filter((person) => person.data.role !== 'Alumni');
  return people.map((person) => ({ params: { slug: person.id }, props: { person } }));
}

const { person } = Astro.props;
const { Content } = await render(person);
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const assetUrl = (path?: string) => path?.startsWith(base) ? path : path?.startsWith('/') ? withBase(path) : path;
const normalize = (value: string) =>
  value
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[().]/g, '')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
const initials = (name: string) =>
  name
    .replace(/\([^)]*\)/g, '')
    .trim()
    .split(/\s+/)
    .map((part) => part[0])
    .join('')
    .slice(0, 2);

const personNames = new Set([person.data.name, ...person.data.aliases].map(normalize));
const authoredByPerson = (authors: string[]) => authors.some((author) => personNames.has(normalize(author)));
const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && authoredByPerson(post.data.authors))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const publications = (await getCollection('publications'))
  .filter((publication) => authoredByPerson(publication.data.authors))
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));
const formatDate = (date: Date) => new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<BaseLayout title={`${person.data.name} | PLSec at VU Amsterdam`}>
  <section class="page-header person-header">
    <div class="container person-profile">
      {person.data.photo ? (
        <img class="profile-photo" src={assetUrl(person.data.photo)} alt="" />
      ) : (
        <div class="profile-photo person-initials" aria-hidden="true">
          {initials(person.data.name)}
        </div>
      )}
      <div>
        <p class="eyebrow">{person.data.role}</p>
        <h1>{person.data.name}</h1>
        {person.data.email && (
          <p class="lead"><a href={`mailto:${person.data.email}`}>Contact</a></p>
        )}
        {person.data.website && (
          <p class="lead"><a href={person.data.website}>Personal website</a></p>
        )}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container narrow">
      <div class="prose">
        <Content />
      </div>
      {person.data.interests.length > 0 && (
        <div class="tags">
          {person.data.interests.map((interest) => <span>{interest}</span>)}
        </div>
      )}
    </div>
  </section>

  {(publications.length > 0 || posts.length > 0) && (
    <section class="section alt">
      <div class="container narrow">
        {publications.length > 0 && (
          <>
            <h2 class="role-heading">Publications</h2>
            <div class="list">
              {publications.map((publication) => (
                <article class="card publication">
                  <h3>{publication.data.title}</h3>
                  <div><AuthorList authors={publication.data.authors} /></div>
                  <div class="venue">{publication.data.venue}, {publication.data.year}</div>
                  {publication.data.links.length > 0 && (
                    <div class="tags">
                      {publication.data.links.map((link) => <a href={link.url}>{link.label}</a>)}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </>
        )}

        {posts.length > 0 && (
          <>
            <h2 class="role-heading">Posts</h2>
            <div class="list">
              {posts.map((post) => (
                <article class="card news-card">
                  <p class="meta">{formatDate(post.data.date)}</p>
                  <h3><a href={withBase(`/posts/${post.id}/`)}>{post.data.title}</a></h3>
                  <p class="byline"><AuthorList authors={post.data.authors} prefix="By " /></p>
                  <p>{post.data.summary}</p>
                  {post.data.tags.length > 0 && (
                    <div class="tags">
                      {post.data.tags.map((tag) => <span>{tag}</span>)}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </>
        )}
      </div>
    </section>
  )}
</BaseLayout>
