---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<BaseLayout title="Page not found | PLSec at VU Amsterdam">
  <section class="page-header">
    <div class="container narrow">
      <h1>Page not found</h1>
      <p class="lead">The page may have moved during the site migration.</p>
      <div class="actions">
        <a class="button" href={withBase('/')}>Go home</a>
      </div>
    </div>
  </section>
</BaseLayout>
