---
import type { CollectionEntry } from 'astro:content';
import AuthorList from './AuthorList.astro';

interface Props {
  item: CollectionEntry<'news'> | CollectionEntry<'posts'>;
  basePath?: 'news' | 'posts';
}

const { item, basePath = 'news' } = Astro.props as Props;
const date = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' }).format(item.data.date);
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const href = 'link' in item.data && item.data.link ? item.data.link : withBase(`/${basePath}/${item.id}/`);
const image = 'image' in item.data ? item.data.image : undefined;
---

<article class="card news-card">
  {image && (
    <a class="news-card-image" href={href} aria-label={item.data.title}>
      <img src={image} alt="" loading="lazy" />
    </a>
  )}
  <p class="meta">{date}</p>
  <h3><a href={href}>{item.data.title}</a></h3>
  {'authors' in item.data && item.data.authors.length > 0 && (
    <p class="byline"><AuthorList authors={item.data.authors} prefix="By " /></p>
  )}
  <p>{item.data.summary}</p>
  {'tags' in item.data && item.data.tags.length > 0 && (
    <div class="tags">
      {item.data.tags.map((tag) => <span>{tag}</span>)}
    </div>
  )}
</article>
